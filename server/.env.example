# Variables de entorno del servidor
# Copia este archivo como .env y completa tus valores reales

# Puerto del servidor
PORT=4000

# PostgreSQL — obténlo desde Railway (Settings > Variables)
DATABASE_URL=postgresql://usuario:password@host:puerto/nombre_db

# JWT — cualquier string largo y secreto
JWT_SECRET=tu_clave_secreta_muy_larga_aqui_cambiala

# Cloudinary — obtenlos desde https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173
